// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  stripeCustomerId        String?
  subscriptionActive      Boolean   @default(false)
  isAdmin                 Boolean   @default(false)
  suspended               Boolean   @default(false)
  plan                    String?
  planSource              String?
  planActivatedAt         DateTime?
  onboardingCompletedAt   DateTime?
  lastNotificationCheckAt DateTime?
  createdAt               DateTime  @default(now())
  sites                   Site[]
}

model Site {
  id                    String      @id @default(uuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  url                   String
  wpUrl                 String?
  wpUsername            String?
  wpAppPasswordEncrypted String?    // Encrypted application password
  customInstructions    String?
  gscConnected          Boolean     @default(false)
  gscUrl                String?
  businessProfile       String?     // Stored as JSON string
  detectedSeoPlugin     String?     // yoast | rankmath | none
  wpConnectedAt         DateTime?
  createdAt             DateTime    @default(now())
  audits                Audit[]
  auditItems            AuditItem[]
}

model Audit {
  id                  String      @id @default(uuid())
  siteId              String
  site                Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scorePerformance    Int         @default(0)
  scoreSeo            Int         @default(0)
  scoreSeoGoogle      Int?
  scoreAccessibility  Int?
  scoreBestPractices  Int?
  lcpSeconds          Float?
  clsScore            Float?
  inpMilliseconds     Float?
  status              String      @default("pending") // pending, completed, failed
  aiScanError         String?
  pageSpeedScanError  String?
  businessProfileError String?
  createdAt           DateTime    @default(now())
  items               AuditItem[]
}

model AuditItem {
  id             String    @id @default(uuid())
  auditId        String
  audit          Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)
  siteId         String
  site           Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  type           String    // "meta_title" | "meta_description" | "blog_post" | "broken_link" | "missing_alt" | "schema_markup"
  targetUrl      String
  currentValue   String?   // Store HTML, text or json
  suggestedValue String?   // Store recommended title, content, etc.
  status         String    @default("pending") // pending | approved | rejected | applied
  appliedAt      DateTime?
  errorMessage   String?
  wpPostId       String?
  updatedAt      DateTime  @default(now()) @updatedAt
  createdAt      DateTime  @default(now())
}

model ApiUsageLog {
  id        String   @id @default(uuid())
  provider  String   // e.g. 'gemini'/'openrouter'/'groq'
  callType  String   // 'generateContent'/'generateStructuredJson'
  success   Boolean
  userId    String?
  createdAt DateTime @default(now())
}

model AppSettings {
  id                   String   @id @default("singleton")
  aiProvider           String?  // null means fallback to env default
  auditCooldownMinutes Int?     // null means fallback to env default
  updatedAt            DateTime @updatedAt
}

model ImpersonationLog {
  id           String   @id @default(uuid())
  adminUserId  String
  targetUserId String
  reason       String?
  startedAt    DateTime @default(now())
}

model RateLimitLog {
  id        String   @id @default(uuid())
  userId    String
  routeKey  String
  createdAt DateTime @default(now())

  @@index([userId, routeKey, createdAt])
}

